<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Lumina AI</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; background: #f4f4f4; }
        #chat-box { width: 80%; max-width: 600px; height: 400px; border: 1px solid #ccc; background: white; overflow-y: scroll; padding: 20px; margin-top: 50px; border-radius: 10px; }
        .input-area { margin-top: 20px; display: flex; gap: 10px; width: 80%; max-width: 600px; }
        input { flex: 1; padding: 10px; border-radius: 5px; border: 1px solid #ccc; }
        button { padding: 10px 20px; background: #333; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <h1>Lumina AI</h1>
    <div id="chat-box"></div>
    <div class="input-area">
        <input type="text" id="userInput" placeholder="Mesajınızı yazın...">
        <button onclick="sendMessage()">Gönder</button>
    </div>

    <script>
        async function sendMessage() {
            const input = document.getElementById('userInput');
            const chatBox = document.getElementById('chat-box');
            if(!input.value) return;

            chatBox.innerHTML += `<p><b>Siz:</b> ${input.value}</p>`;
            const response = await fetch('/chat', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({message: input.value})
            });
            const data = await response.json();
            chatBox.innerHTML += `<p><b>Lumina:</b> ${data.reply}</p>`;
            input.value = '';
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>
</body>
</html>
